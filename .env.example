# Select which account the runtime should use.
ALPACA_ENV=paper

# Option 1: set generic credentials for the active environment only.
# ALPACA_KEY=your_active_alpaca_key
# ALPACA_SECRET=your_active_alpaca_secret

# Option 2: set both pairs and let ALPACA_ENV choose between them.
ALPACA_PAPER_KEY=your_paper_alpaca_key
ALPACA_PAPER_SECRET=your_paper_alpaca_secret
ALPACA_LIVE_KEY=your_live_alpaca_key
ALPACA_LIVE_SECRET=your_live_alpaca_secret

# Optional: future error reporting destination.
ERROR_WEBHOOK_URL=https://your-domain.example/api/errors

# Optional website-facing published data output.
# SITE_DATA_ROOT=frontend/data

# Optional S3 publish step for those same site-data files.
# S3_PUBLISH_ENABLED=true
# S3_BUCKET_NAME=momentum-run-data
# S3_PREFIX=
# AWS_REGION=eu-west-2
